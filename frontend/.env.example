# API base URL (used at build time – baked into the JS bundle by Vite).
# Set this to the public URL of your backend service (e.g. on Railway).
# If not set, the frontend defaults to /api (works when BACKEND_URL proxy is active).
VITE_API_URL=

# Backend URL used by the Vite preview server to proxy /api requests at runtime.
# Set this to the internal or public URL of your backend service.
# Example: https://your-backend.railway.app
BACKEND_URL=
